{
    "name": "tsars/ddd-generator",
    "description": "CLI tool to generate DDD structure: bounded contexts, aggregates, entities, VOs, events, commands, queries and tests",
    "type": "project",
    "license": "MIT",
    "version": "1.0.1",
    "authors": [
        {
            "name": "Sergey Tsarikov",
            "email": "sergey.tsarikov@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "symfony/console": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "YourVendor\\DDDGenerator\\": "src/"
        }
    },
    "bin": [
        "ddd.php"
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}