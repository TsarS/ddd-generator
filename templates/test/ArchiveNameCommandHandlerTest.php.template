<?php
declare(strict_types=1);

namespace Medigi\Tests\Application\Command\Archive;

use PHPUnit\Framework\TestCase;
use Medigi\##Application##\Application\##Name##\Command\Archive\Archive##Name##Command;
use Medigi\##Application##\Application\##Name##\Command\Archive\Archive##Name##CommandHandler;
use Medigi\##Application##\Domain\Entity\##Name##;
use Medigi\##Application##\Domain\Repository\##Name##RepositoryInterface;
use Medigi\##Application##\Domain\VO\ID;
use Medigi\##Application##\Domain\VO\Status;
use Mockery;

class Archive##Name##CommandHandlerTest extends TestCase
{
    private Archive##Name##CommandHandler $handler;
    private $repository;

    protected function setUp(): void
    {
        $this->repository = Mockery::mock(##Name##RepositoryInterface::class);
        $this->handler = new Archive##Name##CommandHandler($this->repository);
    }

    public function testHandleArchives##Name##(): void
    {
        $id = ID::generate();
        $entity = ##Name##::create($id, 'Test');

        $command = new Archive##Name##Command($id);

        $this->repository
            ->shouldReceive('findById')
            ->with($id)
            ->andReturn($entity);
        $this->repository
            ->shouldReceive('save')
            ->once()
            ->with($entity);

        $this->handler->handle($command);

        $this->assertEquals(Status::Archived, $entity->getStatus());
    }

    public function testHandleNotFoundThrowsException(): void
    {
        $id = ID::generate();
        $command = new Archive##Name##Command($id);

        $this->repository
            ->shouldReceive('findById')
            ->with($id)
            ->andReturn(null);

        $this->expectException(\RuntimeException::class);
        $this->handler->handle($command);
    }
}