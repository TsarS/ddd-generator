<?php
declare(strict_types=1);

namespace ##AppName\Tests\Domain\Event;

use PHPUnit\Framework\TestCase;
use ##AppName\##Application##\Domain\Event\##Name##\##Name##Archived;
use ##AppName\##Application##\Domain\VO\ID;

class ##Name##ArchivedTest extends TestCase
{
    public function testEventCreation(): void
    {
        $id = ID::generate();
        $occurredOn = new \DateTimeImmutable();

        $event = new ##Name##Archived($id, $occurredOn);

        $this->assertEquals($id, $event->getId());
        $this->assertInstanceOf(\DateTimeImmutable::class, $event->getOccurredOn());
    }

    public function testEventHasCorrectName(): void
    {
        $event = new ##Name##Archived(ID::generate(), new \DateTimeImmutable());

        $this->assertEquals('##Name##Archived', $event->getEventName());
    }
}